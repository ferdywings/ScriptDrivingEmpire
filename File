-- ================== COLLECT ATM via YELLOW COIN / BILLBOARD ==================
local function collectATMs()
    atmList = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then
            local hasCoin = false
            if obj:FindFirstChildWhichIsA("ImageLabel") and obj.ImageLabel.Image:lower():find("dollar") or obj.ImageLabel.Image:lower():find("coin") then
                hasCoin = true
            elseif obj:FindFirstChild("TextLabel") and (obj.TextLabel.Text:find("$") or obj.TextLabel.Text:lower():find("money") or obj.TextLabel.Text:lower():find("cash")) then
                hasCoin = true
            end
            
            if hasCoin then
                local parentModel = obj:FindFirstAncestorWhichIsA("Model") or obj.Parent
                local posPart = parentModel.PrimaryPart or parentModel:FindFirstChild("HumanoidRootPart") or parentModel:FindFirstChildWhichIsA("BasePart")
                if posPart then
                    table.insert(atmList, {
                        pos = posPart.Position,
                        gui = obj,
                        model = parentModel
                    })
                end
            end
        end
        
        -- Backup: ProximityPrompt kalau masih ada di beberapa ATM
        if obj:IsA("ProximityPrompt") and (obj.Parent.Name:lower():find("atm") or obj.ActionText:lower():find("rob") or obj.ActionText:lower():find("bust")) then
            local posPart = obj.Parent.PrimaryPart or obj.Parent:FindFirstChildWhichIsA("BasePart")
            if posPart then
                table.insert(atmList, {pos = posPart.Position, prompt = obj})
            end
        end
    end
    print("[CUCUR V4] Ditemukan " .. #atmList .. " ATM (via coin kuning / gui)!")
end

-- ================== AUTO BOBOL + ANTI POLISI ==================
local atmConnection
local function startAutoATM()
    if atmConnection then atmConnection:Disconnect() end
    
    atmConnection = RunService.Heartbeat:Connect(function()
        if not autoATMEnabled then return end
        
        local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot or #atmList == 0 then 
            Status.Text = "No ATM found or not in Outlaw role!"
            return 
        end
        
        local current = atmList[currentATM]
        if not current then currentATM = 1 return end
        
        -- TELEPORT DEKAT ATM (agar coin kuning muncul & interactable)
        myRoot.CFrame = CFrame.new(current.pos + Vector3.new(0, 3, -2))  -- Depan sedikit
        
        task.wait(0.4)  -- Tunggu load indicator
        
        -- Coba fire prompt kalau ada
        if current.prompt then
            pcall(function() fireproximityprompt(current.prompt) end)
        end
        
        -- Simulate click / interact (untuk sistem coin kuning yang butuh klik)
        pcall(function()
            VirtualUser:ClickButton1(Vector2.new(workspace.CurrentCamera.ViewportSize.X/2, workspace.CurrentCamera.ViewportSize.Y/2))
            -- Atau hold kalau perlu: VirtualUser:Button1Down() ... wait ... Button1Up()
        end)
        
        Status.Text = "Auto Robbing ATM #" .. currentATM .. "/" .. #atmList .. " (coin kuning)"
        Status.TextColor3 = Color3.fromRGB(255, 215, 0)  -- Kuning seperti coin
        
        -- ANTI POLISI
        local policeNearby = false
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and plr.Team and plr.Team.Name:lower():find("police") or plr.Team.Name:lower():find("security") then
                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (myRoot.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                    if dist < 40 then
                        policeNearby = true
                        break
                    end
                end
            end
        end
        
        if policeNearby then
            currentATM = math.random(1, #atmList)
            Status.Text = "🚨 POLISI DEKAT! Pindah ATM random..."
            Status.TextColor3 = Color3.fromRGB(255, 100, 0)
            task.wait(1.5)
        else
            task.wait(2.5)  -- Waktu bust ATM normal (sesuaikan kalau terlalu cepat/ lambat)
            currentATM = currentATM % #atmList + 1
        end
    end)
end

-- Refresh list player (lock teleport)
local function refreshPlayerList()
    for _, child in pairs(Scroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 35)
            btn.BackgroundColor3 = Color3.fromRGB(30,30,45)
            btn.Text = plr.Name
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Font = Enum.Font.Gotham
            btn.Parent = Scroll
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
            
            btn.MouseButton1Click:Connect(function()
                targetPlayer = plr
                Status.Text = "Target locked: " .. plr.Name
            end)
        end
    end
    Scroll.CanvasSize = UDim2.new(0,0,0, UIList.AbsoluteContentSize.Y)
end

