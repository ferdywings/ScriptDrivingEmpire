-- [[ CUCUR CATCHER HUB - Lock Teleport + Auto ATM ]] --
-- Buat nangkap pembobol ATM di Driving Empire

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local player = Players.LocalPlayer
local guiName = "CucurCatcherHub_V2"

-- Hapus GUI lama
if player.PlayerGui:FindFirstChild(guiName) then player.PlayerGui[guiName]:Destroy() end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = guiName
ScreenGui.Parent = player:WaitForChild("PlayerGui")

local Main = Instance.new("Frame")
Main.Size = UDim2.new(0, 280, 0, 380)
Main.Position = UDim2.new(0.7, 0, 0.3, 0)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 25)
Main.BorderSizePixel = 0
Main.Active = true
Main.Draggable = true
Main.Parent = ScreenGui

Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)
local stroke = Instance.new("UIStroke", Main)
stroke.Color = Color3.fromRGB(0, 255, 200)
stroke.Thickness = 2

-- Title
local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundTransparency = 1
Title.Text = "CUCUR CATCHER HUB"
Title.TextColor3 = Color3.fromRGB(0, 255, 200)
Title.Font = Enum.Font.GothamBlack
Title.TextSize = 20

-- Status
local Status = Instance.new("TextLabel", Main)
Status.Position = UDim2.new(0, 10, 0, 50)
Status.Size = UDim2.new(1, -20, 0, 20)
Status.BackgroundTransparency = 1
Status.Text = "Idle - Pilih target"
Status.TextColor3 = Color3.fromRGB(200, 200, 200)
Status.Font = Enum.Font.Gotham

-- Auto ATM Toggle
local AutoATM = Instance.new("TextButton", Main)
AutoATM.Position = UDim2.new(0.1, 0, 0.2, 0)
AutoATM.Size = UDim2.new(0.8, 0, 0, 40)
AutoATM.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
AutoATM.Text = "AUTO BOBOL ATM : OFF"
AutoATM.TextColor3 = Color3.new(1,1,1)
AutoATM.Font = Enum.Font.GothamBold
Instance.new("UICorner", AutoATM).CornerRadius = UDim.new(0,8)

-- Lock Teleport Toggle
local LockBtn = Instance.new("TextButton", Main)
LockBtn.Position = UDim2.new(0.1, 0, 0.32, 0)
LockBtn.Size = UDim2.new(0.8, 0, 0, 40)
LockBtn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
LockBtn.Text = "LOCK TELEPORT : OFF"
LockBtn.TextColor3 = Color3.new(1,1,1)
LockBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", LockBtn).CornerRadius = UDim.new(0,8)

-- Player List (Scrolling)
local Scroll = Instance.new("ScrollingFrame", Main)
Scroll.Position = UDim2.new(0.1, 0, 0.45, 0)
Scroll.Size = UDim2.new(0.8, 0, 0, 180)
Scroll.BackgroundColor3 = Color3.fromRGB(20,20,30)
Scroll.ScrollBarThickness = 6
Instance.new("UICorner", Scroll).CornerRadius = UDim.new(0,8)

local UIList = Instance.new("UIListLayout", Scroll)
UIList.Padding = UDim.new(0, 5)

local targetPlayer = nil
local autoATMEnabled = false
local lockEnabled = false

-- Fungsi Auto ATM (rob otomatis)
local function startAutoATM()
    spawn(function()
        while autoATMEnabled and task.wait(0.3) do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                for _, obj in pairs(Workspace:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") and obj.Parent and (obj.Parent.Name:find("ATM") or obj.Parent:FindFirstChildWhichIsA("BillboardGui")) then
                        local dist = (player.Character.HumanoidRootPart.Position - obj.Parent.Position).Magnitude
                        if dist < 25 then
                            fireproximityprompt(obj)
                        end
                    end
                end
            end
        end
    end)
end

-- Update Player List
local function refreshPlayerList()
    for _, child in pairs(Scroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 30)
            btn.BackgroundColor3 = Color3.fromRGB(30,30,45)
            btn.Text = plr.Name
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Font = Enum.Font.Gotham
            btn.Parent = Scroll
            
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)
            
            btn.MouseButton1Click:Connect(function()
                targetPlayer = plr
                Status.Text = "Target: " .. plr.Name .. " (siap nangkap!)"
                Status.TextColor3 = Color3.fromRGB(0, 255, 100)
            end)
        end
    end
    Scroll.CanvasSize = UDim2.new(0,0,0, UIList.AbsoluteContentSize.Y)
end

Players.PlayerAdded:Connect(refreshPlayerList)
Players.PlayerRemoving:Connect(refreshPlayerList)
refreshPlayerList()

-- Toggle Auto ATM
AutoATM.MouseButton1Click:Connect(function()
    autoATMEnabled = not autoATMEnabled
    if autoATMEnabled then
        AutoATM.BackgroundColor3 = Color3.fromRGB(60, 255, 100)
        AutoATM.Text = "AUTO BOBOL ATM : ON"
        startAutoATM()
    else
        AutoATM.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
        AutoATM.Text = "AUTO BOBOL ATM : OFF"
    end
end)

-- Toggle Lock Teleport
LockBtn.MouseButton1Click:Connect(function()
    lockEnabled = not lockEnabled
    if lockEnabled and targetPlayer then
        LockBtn.BackgroundColor3 = Color3.fromRGB(60, 255, 100)
        LockBtn.Text = "LOCK TELEPORT : ON"
    else
        LockBtn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
        LockBtn.Text = "LOCK TELEPORT : OFF"
    end
end)

-- Lock Teleport Logic (nge-follow target)
RunService.Heartbeat:Connect(function()
    if lockEnabled and targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if myRoot then
            local targetPos = targetPlayer.Character.HumanoidRootPart.Position
            myRoot.CFrame = CFrame.new(targetPos + Vector3.new(0, 5, -4)) -- ikut di belakang + atas
            Status.Text = "Mengunci " .. targetPlayer.Name .. " (sedang ngejar!)"
        end
    end
end)

print("Cucur Catcher Hub Loaded! Selamat menangkap pembobol ATM 🚨")
