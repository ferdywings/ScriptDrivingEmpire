-- ================== COLLECT ATM (FIXED & LEBIH AKURAT) ==================
local function collectATMs()
    atmList = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local parent = obj.Parent
            if parent and (parent.Name:lower():find("atm") or 
                           (obj.ActionText and (obj.ActionText:lower():find("rob") or obj.ActionText:lower():find("atm"))) or
                           parent:FindFirstChildWhichIsA("BillboardGui")) then
                
                local posPart = parent.PrimaryPart or parent:FindFirstChild("HumanoidRootPart") or parent:FindFirstChildWhichIsA("BasePart")
                if posPart then
                    table.insert(atmList, {
                        pos = posPart.Position,
                        prompt = obj,
                        model = parent
                    })
                end
            end
        end
    end
    print("[CUCUR] Ditemukan " .. #atmList .. " ATM! Auto farm siap.")
end

collectATMs()  -- Collect saat script dijalankan

-- ================== AUTO ATM + ANTI POLISI ==================
local atmConnection
local function startAutoATM()
    if atmConnection then atmConnection:Disconnect() end
    
    atmConnection = RunService.Heartbeat:Connect(function()
        if not autoATMEnabled then return end
        
        local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot or #atmList == 0 then return end
        
        local current = atmList[currentATM]
        if not current then currentATM = 1 return end
        
        -- TELEPORT KE ATM
        myRoot.CFrame = CFrame.new(current.pos + Vector3.new(0, 8, 0))
        
        -- FIRE PROMPT (rob)
        if current.prompt then
            pcall(function() fireproximityprompt(current.prompt) end)
        end
        
        Status.Text = "Auto ATM: Robbing #" .. currentATM .. "/" .. #atmList
        Status.TextColor3 = Color3.fromRGB(0, 255, 100)
        
        -- ANTI POLISI: Cek player dekat
        local policeNearby = false
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (myRoot.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                if dist < 40 then
                    policeNearby = true
                    break
                end
            end
        end
        
        if policeNearby then
            currentATM = math.random(1, #atmList)  -- Pindah ke ATM random
            Status.Text = "🚨 POLISI DETECTED! Pindah ke ATM lain..."
            Status.TextColor3 = Color3.fromRGB(255, 100, 0)
            task.wait(1)
        else
            task.wait(1.8)  -- Waktu rob normal
            currentATM = currentATM % #atmList + 1
        end
    end)
end

-- ================== REFRESH PLAYER LIST ==================
local function refreshPlayerList()
    for _, child in pairs(Scroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 35)
            btn.BackgroundColor3 = Color3.fromRGB(30,30,45)
            btn.Text = plr.Name
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Font = Enum.Font.Gotham
            btn.Parent = Scroll
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
            
            btn.MouseButton1Click:Connect(function()
                targetPlayer = plr
                Status.Text = "Target: " .. plr.Name
            end)
        end
    end
    Scroll.CanvasSize = UDim2.new(0,0,0, UIList.AbsoluteContentSize.Y)
end

