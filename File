-- ================== IMPROVED ATM DETECTION (Yellow Coin + Prompt) ==================
local function collectATMs()
    atmList = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        -- 1. Yellow Coin / Dollar Sign (BillboardGui)
        if obj:IsA("BillboardGui") and obj:FindFirstChildWhichIsA("ImageLabel") then
            local img = obj.ImageLabel.Image:lower()
            if img:find("dollar") or img:find("coin") or img:find("cash") or img:find("money") then
                local model = obj:FindFirstAncestorWhichIsA("Model") or obj.Parent
                local part = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
                if part then
                    table.insert(atmList, {pos = part.Position, model = model})
                end
            end
        end
        
        -- 2. ProximityPrompt (backup)
        if obj:IsA("ProximityPrompt") and (obj.ActionText:lower():find("rob") or obj.ActionText:lower():find("atm") or obj.Parent.Name:lower():find("atm")) then
            local part = obj.Parent.PrimaryPart or obj.Parent:FindFirstChildWhichIsA("BasePart")
            if part then
                table.insert(atmList, {pos = part.Position, prompt = obj})
            end
        end
        
        -- 3. Part name mengandung ATM/Cash
        if obj:IsA("BasePart") and (obj.Name:lower():find("atm") or obj.Name:lower():find("cash")) then
            table.insert(atmList, {pos = obj.Position + Vector3.new(0,5,0)})
        end
    end
    
    Status.Text = "Ditemukan " .. #atmList .. " ATM (klik SCAN lagi kalau 0)"
    print("✅ V5 Ditemukan " .. #atmList .. " ATM!")
end

-- ================== AUTO BOBOL + ANTI POLISI ==================
local atmConnection
local function startAutoATM()
    if atmConnection then atmConnection:Disconnect() end
    atmConnection = RunService.Heartbeat:Connect(function()
        if not autoATMEnabled then return end
        local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot or #atmList == 0 then return end

        local current = atmList[currentATM]
        myRoot.CFrame = CFrame.new(current.pos + Vector3.new(0, 4, -3))

        if current.prompt then
            pcall(function() fireproximityprompt(current.prompt) end)
        end

        Status.Text = "Robbing ATM #" .. currentATM .. " (coin kuning)"
        
        -- Anti Polisi
        local policeNear = false
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (myRoot.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                if dist < 35 then
                    policeNear = true
                    break
                end
            end
        end
        if policeNear then
            currentATM = math.random(1, #atmList)
            task.wait(1)
        else
            task.wait(2.2)
            currentATM = currentATM % #atmList + 1
        end
    end)
end

-- ================== LOCK TELEPORT - SUDAH DIPERBAIKI (Multi Root) ==================
local function getRoot(char)
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") 
        or char:FindFirstChild("UpperTorso") 
        or char:FindFirstChild("LowerTorso") 
        or char:FindFirstChild("Torso") 
        or char.PrimaryPart 
        or char:FindFirstChildWhichIsA("BasePart")
end

RunService.Heartbeat:Connect(function()
    if lockEnabled and targetPlayer then
        local targetChar = targetPlayer.Character
        if targetChar then
            local targetRoot = getRoot(targetChar)
            local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot and myRoot then
                myRoot.CFrame = CFrame.new(targetRoot.Position + Vector3.new(0, 5, -4))
                Status.Text = "LOCKED → " .. targetPlayer.Name
            end
        end
    end
end)

